# 独立分离部署（前端单独托管，跨域调用 Xboard 后端 API）
# 用法：复制为 .env.standalone（已被 .gitignore 忽略），按需修改后执行
#   npm run build:standalone
# 产物在 dist/，base 为根路径，可直接丢到任意静态服务器 / CDN / Vercel。

# 切到独立模式：base=/ 且不再生成 manifest.json
VITE_DEPLOY_MODE=standalone

# 后端 origin（带协议、不带结尾斜杠）。前端所有 /api/v2/* 请求都打这里。
# Xboard 出厂 config/cors.php 已是 allowed_origins:*，无需改后端。
VITE_API_BASE=https://your-backend-domain.com

# 后端管理路由前缀（Xboard 的 secure_path / frontend_admin_path）。
VITE_SECURE_PATH=your-secure-path
